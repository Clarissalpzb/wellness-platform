generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ─────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations  Location[]
  users      User[]
  classes    Class[]
  packages   Package[]
  products   Product[]
  campaigns  Campaign[]
  insights   Insight[]
  auditLogs  AuditLog[]
  coupons    Coupon[]
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  phone          String?
  timezone       String   @default("America/Mexico_City")
  businessHours  Json     @default("{}") // { mon: { open: "07:00", close: "21:00" }, ... }
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classSchedules ClassSchedule[]
  spaces         Space[]

  @@index([organizationId])
}

model Space {
  id         String @id @default(cuid())
  locationId String
  name       String
  capacity   Int
  amenities  Json   @default("[]")

  location       Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  classSchedules ClassSchedule[]

  @@index([locationId])
}

// ─── Users & Auth ──────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  HEAD_COACH
  FRONT_DESK
  COACH
  CLIENT
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  DateTime?
  passwordHash   String?
  role           Role     @default(CLIENT)
  organizationId String?
  locationId     String?
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  healthFlags    Json     @default("[]")
  preferences    Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts         Account[]
  sessions         Session[]
  bookings         Booking[]
  waitlistEntries  WaitlistEntry[]
  userPackages     UserPackage[]
  transactions     Transaction[]
  coachProfile     CoachProfile?
  referral         Referral?
  friendshipsA     Friendship[]      @relation("FriendA")
  friendshipsB     Friendship[]      @relation("FriendB")
  insightActions   InsightAction[]
  auditLogs        AuditLog[]

  @@index([organizationId])
  @@index([email])
  @@index([role, organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Coach ─────────────────────────────────────────────────

model CoachProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  bio            String?
  specialties    Json    @default("[]")
  certifications Json    @default("[]")
  photoUrl       String?
  referralCode   String? @unique

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSchedules     ClassSchedule[]
  compensationRules  CoachCompensation[]
  availability       CoachAvailability[]
  referrals          Referral[]
}

model CoachCompensation {
  id             String @id @default(cuid())
  coachProfileId String
  type           CompensationType
  amount         Float
  classId        String?
  minAttendees   Int?
  maxAttendees   Int?
  effectiveFrom  DateTime @default(now())
  effectiveTo    DateTime?

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  class        Class?       @relation(fields: [classId], references: [id])

  @@index([coachProfileId])
}

enum CompensationType {
  FIXED_PER_CLASS
  PER_ATTENDEE
  PERCENTAGE_REVENUE
  HOURLY
}

// ─── Classes & Scheduling ──────────────────────────────────

model Class {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String  @default("#22c55e")
  duration       Int     // minutes
  maxCapacity    Int
  waitlistMax    Int     @default(5)
  category       String?
  level          String? // beginner, intermediate, advanced
  imageUrl       String?
  isActive       Boolean @default(true)
  cancellationPolicy Json @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedules         ClassSchedule[]
  compensationRules CoachCompensation[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model ClassSchedule {
  id             String    @id @default(cuid())
  classId        String
  locationId     String
  spaceId        String?
  coachProfileId String?
  dayOfWeek      Int       // 0-6 (Sunday-Saturday)
  startTime      String    // "HH:mm" format
  endTime        String    // "HH:mm" format
  isRecurring    Boolean   @default(true)
  specificDate   DateTime? // For one-off classes
  isCancelled    Boolean   @default(false)
  cancelReason   String?
  createdAt      DateTime  @default(now())

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  location     Location      @relation(fields: [locationId], references: [id])
  space        Space?        @relation(fields: [spaceId], references: [id])
  coachProfile CoachProfile? @relation(fields: [coachProfileId], references: [id])
  bookings     Booking[]
  waitlist     WaitlistEntry[]

  @@index([classId])
  @@index([locationId, dayOfWeek])
  @@index([specificDate])
}

// ─── Bookings & Waitlist ───────────────────────────────────

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  classScheduleId String
  userPackageId   String?
  date            DateTime      // The specific date of this booking
  status          BookingStatus @default(CONFIRMED)
  checkedInAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  source          String        @default("app") // app, admin, fitpass
  createdAt       DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id])
  classSchedule ClassSchedule @relation(fields: [classScheduleId], references: [id])
  userPackage   UserPackage?  @relation(fields: [userPackageId], references: [id])

  @@index([userId])
  @@index([classScheduleId, date])
  @@index([date, status])
}

model WaitlistEntry {
  id              String   @id @default(cuid())
  userId          String
  classScheduleId String
  date            DateTime
  position        Int
  promotedAt      DateTime?
  expiredAt       DateTime?
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id])
  classSchedule ClassSchedule @relation(fields: [classScheduleId], references: [id])

  @@unique([userId, classScheduleId, date])
  @@index([classScheduleId, date])
}

// ─── Packages & Purchases ──────────────────────────────────

enum PackageType {
  CLASS_PACK    // X classes
  UNLIMITED     // Unlimited classes for period
  DROP_IN       // Single class
  MEMBERSHIP    // Recurring subscription
}

model Package {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           PackageType
  price          Float
  currency       String      @default("MXN")
  classLimit     Int?        // null = unlimited
  validityDays   Int         // days from purchase
  isActive       Boolean     @default(true)
  stripePriceId  String?
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userPackages UserPackage[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

model UserPackage {
  id            String   @id @default(cuid())
  userId        String
  packageId     String
  classesUsed   Int      @default(0)
  classesTotal  Int?     // null = unlimited
  purchaseDate  DateTime @default(now())
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  stripeSubId   String?  // Stripe subscription ID
  transactionId String?

  user     User      @relation(fields: [userId], references: [id])
  package  Package   @relation(fields: [packageId], references: [id])
  bookings Booking[]

  @@index([userId])
  @@index([userId, isActive])
}

// ─── POS & Transactions ────────────────────────────────────

model Product {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  description    String?
  price          Float
  currency       String  @default("MXN")
  category       String?
  sku            String?
  stockQuantity  Int?
  imageUrl       String?
  isActive       Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum TransactionType {
  PACKAGE_PURCHASE
  PRODUCT_SALE
  REFUND
  ADJUSTMENT
}

enum PaymentMethod {
  STRIPE
  CASH
  TRANSFER
  FITPASS
  COMPLIMENTARY
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  type           TransactionType
  amount         Float
  currency       String          @default("MXN")
  paymentMethod  PaymentMethod
  stripePaymentId String?
  description    String?
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId, createdAt])
}

// ─── Marketing & CRM ──────────────────────────────────────

enum CampaignChannel {
  EMAIL
  WHATSAPP
  PUSH
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Campaign {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  channel        CampaignChannel
  status         CampaignStatus  @default(DRAFT)
  subject        String?
  content        String
  templateId     String?
  segmentFilter  Json            @default("{}")
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analytics    CampaignAnalytics?

  @@index([organizationId])
}

model CampaignAnalytics {
  id         String @id @default(cuid())
  campaignId String @unique
  sent       Int    @default(0)
  delivered  Int    @default(0)
  opened     Int    @default(0)
  clicked    Int    @default(0)
  bounced    Int    @default(0)
  unsubscribed Int  @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── AI Insights ───────────────────────────────────────────

enum InsightStatus {
  NEW
  SEEN
  ACTED
  DISMISSED
  EXPIRED
}

model Insight {
  id              String        @id @default(cuid())
  organizationId  String
  type            String        // schedule, coach, revenue, retention, operations
  category        String
  title           String
  description     String
  impactScore     Int           // 1-10
  confidenceScore Int           // 1-10
  actionabilityScore Int        @default(5) // 1-10
  suggestedActions Json         @default("[]")
  status          InsightStatus @default(NEW)
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now())
  expiresAt       DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actions      InsightAction[]

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([createdAt])
}

model InsightAction {
  id         String   @id @default(cuid())
  insightId  String
  userId     String
  action     String
  result     String?
  createdAt  DateTime @default(now())

  insight Insight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([insightId])
}

// ─── Social ────────────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Friendship {
  id        String           @id @default(cuid())
  userAId   String
  userBId   String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())

  userA User @relation("FriendA", fields: [userAId], references: [id])
  userB User @relation("FriendB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
}

// ─── Coupons ──────────────────────────────────────────────

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  organizationId String
  discountType   DiscountType
  discountValue  Float
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([code])
}

// ─── Audit ─────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String?
  changes        Json     @default("{}")
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
}

// ─── Coach Availability ──────────────────────────────────

model CoachAvailability {
  id             String  @id @default(cuid())
  coachProfileId String
  dayOfWeek      Int     // 0-6
  startTime      String  // "HH:mm"
  endTime        String  // "HH:mm"
  isActive       Boolean @default(true)

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)

  @@unique([coachProfileId, dayOfWeek, startTime])
  @@index([coachProfileId])
}

// ─── Referrals ───────────────────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  coachProfileId  String
  referredUserId  String    @unique
  bonusAmount     Float     @default(0)
  bonusPaid       Boolean   @default(false)
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  coachProfile CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  referredUser User         @relation(fields: [referredUserId], references: [id])

  @@index([coachProfileId])
}
